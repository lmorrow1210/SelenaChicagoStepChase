{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/game/**",
              "components/icons/**",
              "components/navigation/**",
              "ui_kits/selenas-chase/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Press Start 2P|VT323|Barlow Condensed))/i]",
        "message": "Font not provided by the design system. Available: Press Start 2P, VT323, Barlow Condensed."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|colorway|skinTone|hairColor|ring|badge|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: size, colorway, skinTone, hairColor, ring, badge, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|icon|solid|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, icon, solid, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|gold|red|bronze|silver|muted)$/]",
        "message": "<Badge> tone must be one of 'blue' | 'gold' | 'red' | 'bronze' | 'silver' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BingoTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|state|highlight|style|key|ref|className|style|children)$/]",
        "message": "<BingoTile> doesn't accept that prop. Declared props: label, icon, state, highlight, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BingoTile'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:incomplete|progress|complete|free)$/]",
        "message": "<BingoTile> state must be one of 'incomplete' | 'progress' | 'complete' | 'free'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|loading|disabled|fullWidth|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, loading, disabled, fullWidth, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|danger|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'danger' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|glow|padding|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, glow, padding, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|elevated)$/]",
        "message": "<Card> variant must be one of 'default' | 'elevated'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='glow'] > Literal[value!=/^(?:blue|gold|red)$/]",
        "message": "<Card> glow must be one of 'blue' | 'gold' | 'red'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CityBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|quality|locked|size|icon|style|key|ref|className|style|children)$/]",
        "message": "<CityBadge> doesn't accept that prop. Declared props: name, quality, locked, size, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CityBadge'] > JSXAttribute[name.name='quality'] > Literal[value!=/^(?:bronze|silver|gold)$/]",
        "message": "<CityBadge> quality must be one of 'bronze' | 'silver' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CountdownPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:hoursLeft|label|style|key|ref|className|style|children)$/]",
        "message": "<CountdownPill> doesn't accept that prop. Declared props: hoursLeft, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|body|action|accent|style|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, body, action, accent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|color|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|label|type|variant|suffix|disabled|invalid|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, onChange, placeholder, label, type, variant, suffix, disabled, invalid, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:text|numeric)$/]",
        "message": "<Input> variant must be one of 'text' | 'numeric'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LandmarkTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|fact|state|color|icon|style|key|ref|className|style|children)$/]",
        "message": "<LandmarkTile> doesn't accept that prop. Declared props: name, fact, state, color, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LandmarkTile'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:locked|unlocked|today)$/]",
        "message": "<LandmarkTile> state must be one of 'locked' | 'unlocked' | 'today'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapPin'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|label|selena|size|style|key|ref|className|style|children)$/]",
        "message": "<MapPin> doesn't accept that prop. Declared props: variant, label, selena, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapPin'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:current|next|visited)$/]",
        "message": "<MapPin> variant must be one of 'current' | 'next' | 'visited'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapPin'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<MapPin> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PredictionCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:headline|city|value|onChange|onSubmit|submitted|prediction|style|key|ref|className|style|children)$/]",
        "message": "<PredictionCard> doesn't accept that prop. Declared props: headline, city, value, onChange, onSubmit, submitted, prediction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StripPlayer'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|name|pct|colorway|leader|key|ref|className|style|children)$/]",
        "message": "<StripPlayer> doesn't accept that prop. Declared props: id, name, pct, colorway, leader."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: id, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Skeleton'] > JSXAttribute > JSXIdentifier[name!=/^(?:preset|rows|style|key|ref|className|style|children)$/]",
        "message": "<Skeleton> doesn't accept that prop. Declared props: preset, rows, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Skeleton'] > JSXAttribute[name.name='preset'] > Literal[value!=/^(?:leaderboard|landmark|bingo|block)$/]",
        "message": "<Skeleton> preset must be one of 'leaderboard' | 'landmark' | 'bingo' | 'block'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TowerData'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|steps|colorway|key|ref|className|style|children)$/]",
        "message": "<TowerData> doesn't accept that prop. Declared props: label, steps, colorway."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|min|max|step|onChange|label|format|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: value, min, max, step, onChange, label, format, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|value|unit|accent|style|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: icon, label, value, unit, accent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onNavigate|items|style|key|ref|className|style|children)$/]",
        "message": "<TabBar> doesn't accept that prop. Declared props: active, onNavigate, items, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|title|message|icon|onClose|style|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: type, title, message, icon, onClose, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:achievement|social|alert)$/]",
        "message": "<Toast> type must be one of 'achievement' | 'social' | 'alert'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
